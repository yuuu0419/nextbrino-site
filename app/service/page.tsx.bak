        @media (max-width: 640px) {
          .hero { height: 100vh; min-height: 560px; padding-bottom: 18vh; }
          .sv-grid { grid-template-columns: 1fr; }
          .sv-card { padding: 32px 28px; }
          .sv-num { font-size: 4rem; }
        }
      `}</style>
    </main>
  );
}
